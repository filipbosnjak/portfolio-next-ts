GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# Must match the redirect URI used when you obtained GOOGLE_REFRESH_TOKEN
# (OAuth Playground uses this by default):
# GOOGLE_REDIRECT_URI=https://developers.google.com/oauthplayground

# Sending mailbox that owns the refresh token
# GMAIL_SENDER_EMAIL=test@gmail.com
